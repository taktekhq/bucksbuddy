# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.
# See README.md for where to find each value in the Supabase dashboard.

# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard → Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Your deployed origin (no trailing slash). Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
