# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.
# The app also accepts the older NEXT_PUBLIC_* names if you already set those.

# Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard → Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key

# OPTIONAL: pre-fill the login email so you only type a password.
# The email is not secret; leave unset to show an email field instead.
# VITE_OWNER_EMAIL=you@email.com
